# Database
MONGODB_URI=mongodb://127.0.0.1:27017/bieon_db

# JWT Secret (for token signing)
JWT_SECRET=your-super-secret-jwt-key-here

# SMTP Email Configuration (for OTP emails)
# If not configured, OTPs will be logged to console for development
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=Bieon <noreply@your-domain.com>

# WhatsApp Cloud API Configuration (for OTP via WhatsApp)
# If not configured, OTPs will be logged to console for development
WA_CLOUD_TOKEN=your-whatsapp-cloud-api-token
WA_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WA_GRAPH_VERSION=v19.0

# Firebase Admin Configuration
# Use the Firebase service account JSON file: firebase-service-account.json
FIREBASE_CONFIG_PATH=./firebase-service-account.json

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development
